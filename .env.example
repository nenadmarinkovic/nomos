# Mistral API — powers the AI observers' per-event narration.
# Without it the simulation runs fine; observers simply stay silent.
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=

# Optional: override the narration model (defaults to mistral-small-latest).
# MISTRAL_MODEL=mistral-small-latest

# Postgres — saved runs, user accounts (v0.4), chronicle persistence.
# Local development: spin up via `docker compose up -d postgres` (compose file
# in repo root) and the URL below works as-is.
DATABASE_URL="postgresql://nomos:nomos@localhost:5434/nomos?schema=public"

# Better Auth — secret used to sign sessions. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin Better Auth uses for cookies / redirects.
BETTER_AUTH_URL="http://localhost:3000"
